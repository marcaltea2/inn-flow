model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null if this person only ever logs in via OAuth (Open Authorization)
  role          Role      @default(GUEST)
  accounts      Account[]
  sessions      Session[]
  staff         Staff? // present only if role is a staff role
  guest         Guest? // present only if role is GUEST
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Folio {
  id            String      @id @default(cuid())
  reservationId String      @unique
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  status        FolioStatus @default(OPEN)
  charges       Charge[]
  payments      Payment[]
}

model Charge {
  id         String     @id @default(cuid())
  folioId    String
  type       ChargeType
  amount     Decimal    @db.Money // PREPAYMENT_CREDIT is posted as a negative amount at check-in
  postedAt   DateTime   @default(now())
  postedById String?
  folio      Folio      @relation(fields: [folioId], references: [id])
}

model Payment {
  id                    String                 @id @default(cuid())
  folioId               String?
  reservationId         String?
  amount                Decimal                @db.Money
  method                PaymentMethod
  type                  PaymentTransactionType @default(PAYMENT)
  stripePaymentIntentId String?                @unique // set for PAYMENT rows; also doubles as webhook idempotency key
  stripeRefundId        String?                @unique // set for REFUND rows
  paidAt                DateTime               @default(now())
  folio                 Folio?                 @relation(fields: [folioId], references: [id])
  reservation           Reservation?           @relation(fields: [reservationId], references: [id])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  OUT_OF_ORDER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  FRONT_DESK
  ONLINE
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FolioStatus {
  OPEN
  CLOSED
}

enum ChargeType {
  ROOM
  MINIBAR
  SERVICE
  TAX
  ADJUSTMENT
  PREPAYMENT_CREDIT
}

enum PaymentMethod {
  CASH
  CARD
  STRIPE
  BANK_TRANSFER
}

enum PaymentTransactionType {
  PAYMENT
  REFUND
}

enum Role {
  ADMIN
  MANAGER
  FRONT_DESK
  HOUSEKEEPING
  GUEST
}

enum HousekeepingTaskType {
  CLEANING
  INSPECTION
  MAINTENANCE
}

enum HousekeepingTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Guest {
  id            String        @id @default(cuid())
  userId        String?       @unique // null if this guest has no online account (e.g. a walk-in)
  user          User?         @relation(fields: [userId], references: [id])
  name          String
  email         String?       @unique
  phone         String?
  idType        String? // e.g. "Passport", "Driver's License" — make this an enum if the client has a fixed, known list
  idNumber      String?
  idDocumentUrl String? // pointer to secure storage — see PII (Personally Identifiable Information) handling in §7
  notes         String?
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String? // staff who entered this guest (e.g. a walk-in); null if the guest self-registered
  updatedById   String?
}

model HousekeepingTask {
  id           String                 @id @default(cuid())
  roomId       String
  type         HousekeepingTaskType
  assignedToId String?
  status       HousekeepingTaskStatus @default(PENDING)
  dueBy        DateTime?
  room         Room                   @relation(fields: [roomId], references: [id])
  assignedTo   Staff?                 @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  createdById  String?
  updatedById  String? // e.g. the housekeeper who marked it DONE
}

model Reservation {
  id               String            @id @default(cuid())
  guestId          String
  roomId           String
  checkInDate      DateTime // planned — date-only semantics, UTC midnight — see §6.3
  checkOutDate     DateTime // planned
  actualCheckInAt  DateTime? // real timestamp when check-in was processed
  actualCheckOutAt DateTime? // real timestamp when check-out was processed
  checkedInById    String? // staff who processed check-in
  checkedOutById   String? // staff who processed check-out
  status           ReservationStatus @default(PENDING)
  adults           Int
  children         Int               @default(0)
  rateAtBooking    Decimal           @db.Money // snapshot rate — never recompute from RoomType retroactively
  createdById      String? // staff who created it — nullable for online bookings (guestId is the actor then)
  updatedById      String?
  bookingSource    BookingSource     @default(FRONT_DESK)
  paymentStatus    PaymentStatus     @default(UNPAID)
  holdExpiresAt    DateTime? // set only for ONLINE + PENDING; cron sweep releases the room if passed
  guest            Guest             @relation(fields: [guestId], references: [id])
  room             Room              @relation(fields: [roomId], references: [id])
  payments         Payment[] // prepayments made before check-in / before a Folio exists
  folio            Folio?
  statusHistory    StatusHistory[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([roomId, checkInDate, checkOutDate])
  @@index([status, holdExpiresAt]) // for the abandoned-hold sweep query
  @@index([guestId, actualCheckOutAt]) // for guest stay-history lookups
}

model StatusHistory {
  id            String             @id @default(cuid())
  reservationId String
  fromStatus    ReservationStatus?
  toStatus      ReservationStatus
  changedAt     DateTime           @default(now())
  changedById   String? // staff who made the change; null if system/cron-triggered
  reason        String?
  reservation   Reservation        @relation(fields: [reservationId], references: [id])
}

model Room {
  id                String             @id @default(cuid())
  number            String             @unique // e.g. "204" — add a propertyId later if this becomes multi-property
  floor             Int?
  roomTypeId        String
  status            RoomStatus         @default(AVAILABLE)
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdById       String?
  updatedById       String?
}

model RoomType {
  id          String    @id @default(cuid())
  name        String // e.g. "Standard Queen", "Deluxe Suite"
  baseRate    Decimal   @db.Money
  capacity    Int // max guests this room type sleeps
  description String?
  amenities   Amenity[] @relation("RoomTypeAmenities")
  rooms       Room[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String? // nullable — see §4.3 audit-field convention
  updatedById String?
}

model Amenity {
  id        String     @id @default(cuid())
  name      String     @unique // e.g. "Free WiFi", "Mini Fridge", "Balcony"
  roomTypes RoomType[] @relation("RoomTypeAmenities")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

model Setting {
  id                            String   @id @default(cuid())
  cancellationCutoffHours       Int      @default(48) // free-cancellation window before check-in
  cancellationRefundPercent     Int      @default(100) // % refunded if cancelled before the cutoff
  lateCancellationRefundPercent Int      @default(0) // % refunded if cancelled after the cutoff
  noShowRefundPercent           Int      @default(0) // % refunded on a no-show
  updatedAt                     DateTime @updatedAt
  updatedById                   String?
}

model Staff {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  assignedTasks HousekeepingTask[]
}
